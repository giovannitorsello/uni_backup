# TapeGuard v2 — variabili d'ambiente
# Copia in .env e compila tutti i campi prima del deploy

# --- PostgreSQL ---
POSTGRES_USER=tapeguard
POSTGRES_PASSWORD=CAMBIA_PASSWORD_SICURA_MIN32CHAR

# --- Bareos ---
BAREOS_DIRECTOR_PASSWORD=CAMBIA_PASSWORD_DIRECTOR

# --- Bareos build (usato da make clone-bareos e docker build) ---
BAREOS_GIT_TAG=Release/23
BUILD_JOBS=4

# --- MinIO (S3 locale) ---
MINIO_ROOT_USER=tapeguard
MINIO_ROOT_PASSWORD=CAMBIA_PASSWORD_MINIO

# --- Restic / S3 ---
RESTIC_S3_ENDPOINT=http://minio:9000
RESTIC_S3_ACCESS_KEY=tapeguard
RESTIC_S3_SECRET_KEY=CAMBIA_SECRET_MINIO

# --- JWT ---
JWT_SECRET=STRINGA_CASUALE_MIN_64_CARATTERI_CAMBIA_ASSOLUTAMENTE

# --- Email SMTP ---
SMTP_HOST=smtp.esempio.it
SMTP_PORT=587
SMTP_USER=alert@esempio.it
SMTP_PASS=password_smtp
SMTP_FROM=TapeGuard Alert <alert@esempio.it>

# --- Web Push VAPID (genera con: make gen-vapid) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@esempio.it

# --- Alert ---
ALERT_DAYS_BEFORE=3
ALERT_CRON=0 7 * * *

# --- CRM esterno ---
CRM_API_URL=
CRM_API_KEY=
CRM_WEBHOOK_SECRET=

# --- GLPI ---
GLPI_URL=
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
